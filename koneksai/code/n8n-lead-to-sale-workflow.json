    {
      "parameters": {
        "jsCode": "// Normalize and validate incoming lead data\nconst body = $input.first().json;\nconst now = new Date().toISOString();\n\n// Generate lead_id if not provided\nconst lead_id = body.lead_id || `lead-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;\n\n// Normalize phone to E.164: Haiti +509\nlet phone = (body.phone || '').replace(/\\s+/g, '').replace(/-/g, '');\nif (phone.startsWith('509') && !phone.startsWith('+')) {\n  phone = '+' + phone;\n} else if (!phone.startsWith('+')) {\n  phone = '+509' + phone;\n}\n\n// Detect language: default to HT for Haiti\nconst langRaw = (body.lang || '').toUpperCase();\nconst lang = ['FR', 'HT', 'EN'].includes(langRaw) ? langRaw : 'HT';\n\n// Normalize source\nconst validSources = ['facebook_ad', 'instagram_ad', 'whatsapp_dm', 'google_form', 'referral', 'organic_whatsapp', 'website'];\nconst source = validSources.includes(body.source) ? body.source : 'organic_whatsapp';\n\n// Normalize segment\nconst validSegments = ['restaurant', 'pharmacy', 'boutique', 'salon', 'other'];\nconst segment = validSegments.includes(body.segment) ? body.segment : 'other';\n\n// Clean name\nconst name = (body.name || 'Moun sa a').trim().substring(0, 120);\n\nreturn [{\n  json: {\n    lead_id,\n    name,\n    phone,\n    lang,\n    source,\n    segment,\n    timestamp: body.timestamp || now,\n    normalized_at: now,\n    ad_campaign_id: body.ad_campaign_id || null,\n    ad_set_id: body.ad_set_id || null,\n    ad_id: body.ad_id || null,\n    message_text: (body.message_text || '').substring(0, 1000),\n    stage: 'new'\n  }\n}];"
      },
      "id": "node-normalize-data",
      "name": "Normalize Lead Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 400]
    },
