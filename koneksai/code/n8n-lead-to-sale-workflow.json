      "parameters": {
        "jsCode": "// Build Day 1 follow-up offer message\nconst lead = $input.first().json;\nconst name = lead.name.split(' ')[0];\nconst lang = lead.lang || 'HT';\nconst segment = lead.segment || 'other';\n\nconst segmentBenefits = {\n  restaurant: {\n    HT: 'Restoran ki itilize WhatsApp otomatik yo jwenn 40% plis komand yo!',\n    FR: 'Les restaurants utilisant WhatsApp automatique reçoivent 40% de commandes en plus!',\n    EN: 'Restaurants using WhatsApp automation get 40% more orders!'\n  },\n  pharmacy: {\n    HT: 'Famasi yo ka konfime preskripsyon ak livrezon otomat.',\n    FR: 'Les pharmacies peuvent confirmer prescriptions et livraisons automatiquement.',\n    EN: 'Pharmacies can auto-confirm prescriptions and deliveries.'\n  },\n  boutique: {\n    HT: 'Boutik yo k ap itilize WhatsApp doub vant yo nan 3 mwa.',\n    FR: 'Les boutiques utilisant WhatsApp doublent leurs ventes en 3 mois.',\n    EN: 'Boutiques using WhatsApp double their sales in 3 months.'\n  },\n  salon: {\n    HT: 'Salon yo elimine 90% randez-vou rate yo ak konfirmasyon otomat.',\n    FR: 'Les salons éliminent 90% des rendez-vous manqués avec la confirmation automatique.',\n    EN: 'Salons eliminate 90% of missed appointments with auto-confirmation.'\n  },\n  other: {\n    HT: 'Biznis ki itilize WhatsApp otomatik triple repons kliyan yo.',\n    FR: 'Les entreprises utilisant WhatsApp automatique triplent leurs réponses clients.',\n    EN: 'Businesses using WhatsApp automation triple their customer responses.'\n  }\n};\n\nconst benefit = (segmentBenefits[segment] || segmentBenefits.other)[lang];\n\nconst messages = {\n  HT: `${name}, tande sa... 🔥\n\n${benefit}\n\nKoneksAI ka mete sa travay pou biznis ou an nan 48 è.\n\n📱 Pakè Estàtè a: sèlman 5,000 HTG/mwa\n📈 Pakè Kwasans: 10,000 HTG/mwa\n⭐ Pakè Pro: 20,000 HTG/mwa\n\nTou nou aksepte MonCash. Ki pakè ki enterese ou?`,\n  FR: `${name}, écoutez ça... 🔥\n\n${benefit}\n\nKoneksAI peut mettre cela en place pour votre entreprise en 48h.\n\n📱 Pack Starter: seulement 5,000 HTG/mois\n📈 Pack Croissance: 10,000 HTG/mois\n⭐ Pack Pro: 20,000 HTG/mois\n\nNous acceptons MonCash. Quel pack vous intéresse?`,\n  EN: `${name}, hear this... 🔥\n\n${benefit}\n\nKoneksAI can set this up for your business in 48 hours.\n\n📱 Starter Pack: only 5,000 HTG/month\n📈 Growth Pack: 10,000 HTG/month\n⭐ Pro Pack: 20,000 HTG/month\n\nWe accept MonCash. Which package interests you?`\n};\n\nreturn [{ json: { ...lead, followup_text: messages[lang] || messages.HT, followup_day: 1 } }];"
      },
