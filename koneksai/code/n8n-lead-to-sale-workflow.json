    {
      "parameters": {
        "jsCode": "// Build WhatsApp message for French\nconst lead = $input.first().json;\nconst name = lead.name.split(' ')[0];\nconst segment = lead.segment;\n\nconst segmentMap = {\n  restaurant: 'votre restaurant',\n  pharmacy: 'votre pharmacie',\n  boutique: 'votre boutique',\n  salon: 'votre salon',\n  other: 'votre entreprise'\n};\nconst bizLabel = segmentMap[segment] || 'votre entreprise';\n\nconst messageText = `Bonjour ${name}! 👋\n\nMerci de contacter KoneksAI. Nous aidons des entreprises comme ${bizLabel} à attirer plus de clients grâce à l'automatisation WhatsApp.\n\n✅ Réponse en moins d'1 minute\n✅ Messages automatiques 24h/24\n✅ Paiement facile via MonCash\n\nPouvez-vous m'accorder 2 minutes pour vous expliquer comment ça fonctionne?`;\n\nreturn [{ json: { ...lead, reply_text: messageText, lang_used: 'FR' } }];"
      },
      "id": "node-msg-fr",
      "name": "Build Message (FR)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 400]
    },
    {
      "parameters": {
        "jsCode": "// Build WhatsApp message for English\nconst lead = $input.first().json;\nconst name = lead.name.split(' ')[0];\nconst segment = lead.segment;\n\nconst segmentMap = {\n  restaurant: 'your restaurant',\n  pharmacy: 'your pharmacy',\n  boutique: 'your boutique',\n  salon: 'your salon',\n  other: 'your business'\n};\nconst bizLabel = segmentMap[segment] || 'your business';\n\nconst messageText = `Hello ${name}! 👋\n\nThanks for reaching out to KoneksAI. We help businesses like ${bizLabel} get more customers through WhatsApp automation.\n\n✅ Response in under 1 minute\n✅ Automated messages 24/7\n✅ Easy payment via MonCash\n\nCan you spare 2 minutes for me to show you how it works?`;\n\nreturn [{ json: { ...lead, reply_text: messageText, lang_used: 'EN' } }];"
      },
