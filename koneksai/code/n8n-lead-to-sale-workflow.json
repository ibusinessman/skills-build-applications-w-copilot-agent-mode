      "parameters": {
        "jsCode": "// Build WhatsApp message for Haitian Creole\nconst lead = $input.first().json;\nconst name = lead.name.split(' ')[0]; // first name only\nconst segment = lead.segment;\n\nconst segmentMap = {\n  restaurant: 'restoran ou an',\n  pharmacy: 'famasi ou a',\n  boutique: 'boutik ou a',\n  salon: 'salon ou an',\n  other: 'biznis ou an'\n};\nconst bizLabel = segmentMap[segment] || 'biznis ou an';\n\nconst messageText = `Bonjou ${name}! 👋\n\nMèsi pou kontakte KoneksAI. Nou espesyalize nan ede biznis tankou ${bizLabel} jwenn plis kliyan ak WhatsApp otomatik.\n\n✅ Repons nan mwens pase 1 minit\n✅ Mesaj otomatik 24/7\n✅ Peman fasil ak MonCash\n\nEske ou ka ban mwen 2 minit pou m eksplike ou kijan sa travay?`;\n\nreturn [{ json: { ...lead, reply_text: messageText, lang_used: 'HT' } }];"
      },
      "id": "node-msg-ht",
      "name": "Build Message (HT)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 280]
