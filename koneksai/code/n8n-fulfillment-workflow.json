    {
      "parameters": {
        "jsCode": "// Look up lead data from Sheets to get name and lang\n// This node merges payment data with lead context\nconst payment = $input.first().json;\n\n// Generate fulfillment ID\nconst fulfillment_id = `fulfill-${Date.now()}-${Math.random().toString(36).substr(2,9)}`;\n\n// Generate referral code for this client\nconst phone = payment.customer_phone || '';\nconst refCode = 'KNX-' + phone.replace('+', '').slice(-6).toUpperCase();\n\n// Build the client row data\nconst client_id = `client-${Date.now()}-${Math.random().toString(36).substr(2,9)}`;\n\nreturn [{ json: {\n  ...payment,\n  fulfillment_id,\n  client_id,\n  referral_code: refCode,\n  onboard_date: new Date().toISOString().split('T')[0],\n  client_lang: payment.lang || 'HT',\n  client_segment: payment.segment || 'other',\n  setup_guide_url: process.env.SETUP_GUIDE_DRIVE_URL || 'https://drive.google.com/file/d/SETUP_GUIDE_FILE_ID/view?usp=sharing'\n} }];"
      },
      "id": "node-enrich-fulfillment",
      "name": "Enrich with Client Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 400]
