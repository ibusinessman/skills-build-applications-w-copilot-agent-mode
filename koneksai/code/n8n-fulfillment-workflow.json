{
  "name": "KoneksAI — Fulfillment After Payment",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "payment-confirmed",
        "responseMode": "responseNode",
        "options": {
          "rawBody": true
        }
      },
      "id": "node-webhook-payment",
      "name": "Webhook: Payment Confirmed",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [200, 400],
      "webhookId": "koneksai-payment-confirmed-001"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"status\": \"processing\", \"transaction_id\": $json[\"transaction_id\"] }",
        "options": {
          "responseCode": 200
        }
      },
      "id": "node-respond-payment",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [440, 260]
    },
    {
      "parameters": {
        "jsCode": "// Validate MonCash IPN payload\nconst body = $input.first().json;\nconst errors = [];\n\n// Required field validation\nif (!body.transaction_id || typeof body.transaction_id !== 'string' || body.transaction_id.trim() === '') {\n  errors.push('Missing or invalid transaction_id');\n}\nif (!body.amount || typeof body.amount !== 'number' || body.amount <= 0) {\n  errors.push('Missing or invalid amount (must be positive number in HTG)');\n}\nif (!body.status || typeof body.status !== 'string') {\n  errors.push('Missing status field');\n}\nif (!body.customer_phone || typeof body.customer_phone !== 'string') {\n  errors.push('Missing customer_phone');\n}\n\n// Validate phone format (E.164)\nconst phoneRegex = /^\\+[1-9]\\d{7,14}$/;\nif (body.customer_phone && !phoneRegex.test(body.customer_phone)) {\n  errors.push('customer_phone must be in E.164 format (e.g. +50941234567)');\n}\n\n// Validate status\nconst validStatuses = ['success', 'failed', 'pending', 'cancelled', 'refunded'];\nif (body.status && !validStatuses.includes(body.status)) {\n  errors.push(`Invalid status. Must be one of: ${validStatuses.join(', ')}`);\n}\n\nif (errors.length > 0) {\n  throw new Error(`Validation failed: ${errors.join('; ')}`);\n}\n\nreturn [{ json: {\n  ...body,\n  validated_at: new Date().toISOString(),\n  is_valid: true\n} }];"
      },
      "id": "node-validate-payment",
      "name": "Validate Payment Fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 400]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.status }}",
                    "rightValue": "success",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "success"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "node-check-payment-status",
      "name": "Payment Status = success?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [680, 400]
    },
    {
      "parameters": {
        "jsCode": "// Log non-success payment and halt\nconst body = $input.first().json;\nconsole.log(`Payment not processed: status=${body.status}, transaction_id=${body.transaction_id}`);\n\n// Return data for the error log branch\nreturn [{ json: {\n  log_type: 'payment_skipped',\n  reason: `Payment status is '${body.status}', not 'success'. No fulfillment triggered.`,\n  transaction_id: body.transaction_id,\n  timestamp: new Date().toISOString()\n} }];"
      },
      "id": "node-log-non-success",
      "name": "Log Non-Success Payment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 540]
    },
