      "parameters": {
        "jsCode": "// Build language-appropriate onboarding WhatsApp message\nconst client = $input.first().json;\nconst name = (client.customer_name || 'Kliyan').split(' ')[0];\nconst lang = client.client_lang || 'HT';\nconst pkg = client.package || 'starter';\nconst guideUrl = client.setup_guide_url;\n\nconst packageNames = {\n  HT: { starter: 'Estàtè', growth: 'Kwasans', pro: 'Pro', custom: 'Pèsonalize' },\n  FR: { starter: 'Starter', growth: 'Croissance', pro: 'Pro', custom: 'Personnalisé' },\n  EN: { starter: 'Starter', growth: 'Growth', pro: 'Pro', custom: 'Custom' }\n};\n\nconst pkgName = (packageNames[lang] || packageNames.HT)[pkg] || pkg;\n\nconst messages = {\n  HT: `🎉 Byenveni nan fanmi KoneksAI, ${name}!\n\nPeman ou konfime ✅ — Pakè ${pkgName} ou aktif kounye a!\n\nVoici premye etap ou yo:\n\n📖 *Gid Konfigirasyon ou*:\n${guideUrl}\n\n📋 Sa ou bezwen fè:\n1. Telechaje gid la\n2. Suiv etap 1 ak 2 jodia\n3. Mwen pral kontakte ou nan 7 jou pou asire tout bagay ap travay\n\n🚀 Ou pare! Kèsyon? Tou senpleman reponn mesaj sa a.\n\nMèsi pou konfyans ou — n ap grandi ansanm! 🇭🇹`,\n  FR: `🎉 Bienvenue dans la famille KoneksAI, ${name}!\n\nVotre paiement est confirmé ✅ — Votre Pack ${pkgName} est maintenant actif!\n\nVoici vos premières étapes:\n\n📖 *Votre Guide de Configuration*:\n${guideUrl}\n\n📋 À faire:\n1. Téléchargez le guide\n2. Suivez les étapes 1 et 2 aujourd'hui\n3. Je vous contacterai dans 7 jours pour vérifier que tout fonctionne\n\n🚀 Vous êtes prêt! Des questions? Répondez simplement à ce message.\n\nMerci pour votre confiance — grandissons ensemble! 🇭🇹`,\n  EN: `🎉 Welcome to the KoneksAI family, ${name}!\n\nYour payment is confirmed ✅ — Your ${pkgName} Package is now active!\n\nHere are your first steps:\n\n📖 *Your Setup Guide*:\n${guideUrl}\n\n📋 To do:\n1. Download the guide\n2. Follow steps 1 and 2 today\n3. I'll contact you in 7 days to make sure everything is working\n\n🚀 You're all set! Questions? Just reply to this message.\n\nThank you for your trust — let's grow together! 🇭🇹`\n};\n\nreturn [{ json: { ...client, onboarding_message: messages[lang] || messages.HT } }];"
      },
