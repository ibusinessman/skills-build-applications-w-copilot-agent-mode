                    "operator": {
                      "type": "string",
                      "operation": "notContains"
                    }
                  },
                  {
                    "leftValue": "={{ $json.campaign_id !== undefined }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "has_flags"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
