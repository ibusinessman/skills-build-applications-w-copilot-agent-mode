    {
      "parameters": {
        "jsCode": "// Generate HTML daily summary email\nconst kpi = $input.first().json;\n\nconst cacDisplay = kpi.cac_usd !== null ? `$${kpi.cac_usd}` : 'N/A (0 vant jodi a)';\nconst cacColor = kpi.alert_cac_exceeded ? '#e74c3c' : '#27ae60';\nconst churnPct = (kpi.churn_rate * 100).toFixed(1);\nconst convPct = (kpi.conversion_rate * 100).toFixed(1);\n\nconst html = `\n<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>KoneksAI — Rapò Jounalye ${kpi.date}</title>\n<style>\n  body { font-family: Arial, sans-serif; background: #f5f5f5; margin: 0; padding: 20px; }\n  .container { max-width: 600px; margin: 0 auto; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }\n  .header { background: linear-gradient(135deg, #1a1a2e, #16213e); color: white; padding: 30px; text-align: center; }\n  .header h1 { margin: 0; font-size: 24px; }\n  .header p { margin: 8px 0 0; opacity: 0.8; font-size: 14px; }\n  .kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; padding: 24px; }\n  .kpi-card { background: #f8f9fa; border-radius: 8px; padding: 16px; text-align: center; border-left: 4px solid #3498db; }\n  .kpi-card.alert { border-left-color: #e74c3c; background: #fff5f5; }\n  .kpi-card.good { border-left-color: #27ae60; background: #f0fff4; }\n  .kpi-value { font-size: 28px; font-weight: bold; color: #1a1a2e; }\n  .kpi-label { font-size: 12px; color: #666; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; }\n  .section { padding: 0 24px 24px; }\n  .section h2 { color: #1a1a2e; border-bottom: 2px solid #3498db; padding-bottom: 8px; }\n  .metric-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #eee; }\n  .metric-row:last-child { border-bottom: none; }\n  .metric-name { color: #555; }\n  .metric-value { font-weight: bold; color: #1a1a2e; }\n  .alert-banner { background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 16px; margin: 0 24px 24px; }\n  .footer { background: #f8f9fa; padding: 16px 24px; text-align: center; color: #888; font-size: 12px; }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <div class=\"header\">\n    <h1>🇭🇹 KoneksAI</h1>\n    <p>Rapò Jounalye — ${kpi.date}</p>\n    <p style=\"font-size:12px; opacity:0.6;\">Jenere chak maten a 7h (Hay)</p>\n  </div>\n\n  ${kpi.alert_cac_exceeded ? `\n  <div class=\"alert-banner\">\n    ⚠️ <strong>ALÈT CAC:</strong> Koute akizisyon kliyan an ($${kpi.cac_usd}) depase limit $20 USD.\n    Tcheke pèfòmans kanpay Meta Ads ou yo imedyatman.\n  </div>` : ''}\n\n  <div class=\"kpi-grid\">\n    <div class=\"kpi-card\">\n      <div class=\"kpi-value\">${kpi.new_leads}</div>\n      <div class=\"kpi-label\">Nouvo Leads Jodi</div>\n    </div>\n    <div class=\"kpi-card ${kpi.new_clients > 0 ? 'good' : ''}\">\n      <div class=\"kpi-value\">${kpi.new_clients}</div>\n      <div class=\"kpi-label\">Nouvo Kliyan Jodi</div>\n    </div>\n    <div class=\"kpi-card ${kpi.alert_cac_exceeded ? 'alert' : 'good'}\">\n      <div class=\"kpi-value\" style=\"color:${cacColor}\">${cacDisplay}</div>\n      <div class=\"kpi-label\">CAC (Koute Akizisyon)</div>\n    </div>\n    <div class=\"kpi-card good\">\n      <div class=\"kpi-value\">$${kpi.ltv_usd}</div>\n      <div class=\"kpi-label\">LTV Estimasyon</div>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <h2>📊 Detay Metrik</h2>\n    <div class=\"metric-row\">\n      <span class=\"metric-name\">Revni Jodi a</span>\n      <span class=\"metric-value\">$${kpi.total_revenue_usd} USD (${kpi.total_revenue_htg.toLocaleString()} HTG)</span>\n    </div>\n    <div class=\"metric-row\">\n      <span class=\"metric-name\">Depans Meta Ads Jodi a</span>\n      <span class=\"metric-value\">$${kpi.total_ad_spend_usd} USD</span>\n    </div>\n    <div class=\"metric-row\">\n      <span class=\"metric-name\">To Konvèsyon</span>\n      <span class=\"metric-value\">${convPct}%</span>\n    </div>\n    <div class=\"metric-row\">\n      <span class=\"metric-name\">To Churn Mwa Sa a</span>\n      <span class=\"metric-value\">${churnPct}%</span>\n    </div>\n    <div class=\"metric-row\">\n      <span class=\"metric-name\">Total Kliyan Aktif</span>\n      <span class=\"metric-value\">${kpi.active_clients_total}</span>\n    </div>\n    <div class=\"metric-row\">\n      <span class=\"metric-name\">Total Revni Tout Tan</span>\n      <span class=\"metric-value\">$${kpi.total_revenue_all_time_usd.toLocaleString()} USD</span>\n    </div>\n  </div>\n\n  <div class=\"footer\">\n    KoneksAI — Port-au-Prince, Haiti 🇭🇹<br>\n    Rapò sa a jeneratik otomat a 7h chak jou.\n  </div>\n</div>\n</body>\n</html>`;\n\nconst subject = `KoneksAI ${kpi.date}: ${kpi.new_clients} kliyan, CAC ${ kpi.cac_usd !== null ? '$' + kpi.cac_usd : 'N/A' }${kpi.alert_cac_exceeded ? ' ⚠️ ALÈT' : ' ✅'}`;\n\nreturn [{ json: { ...kpi, email_html: html, email_subject: subject } }];"
      },
