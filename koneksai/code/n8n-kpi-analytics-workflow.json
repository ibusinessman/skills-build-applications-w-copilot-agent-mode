    {
      "parameters": {
        "jsCode": "// Flag underperforming campaigns by checking CAC against threshold\n// This runs after email send regardless of CAC alert status\nconst kpi = $input.first().json;\n\nconst CAC_THRESHOLD = 20;\nconst flagged = [];\n\n// In production this would call Meta Ads Insights API\n// For now we flag the overall account if CAC > threshold\nif (kpi.cac_usd !== null && kpi.cac_usd > CAC_THRESHOLD) {\n  flagged.push({\n    date: kpi.date,\n    campaign_id: 'ACCOUNT_LEVEL',\n    cac_usd: kpi.cac_usd,\n    threshold_usd: CAC_THRESHOLD,\n    new_clients: kpi.new_clients,\n    ad_spend_usd: kpi.total_ad_spend_usd,\n    action_required: 'Review targeting, creative, and landing page conversion rate',\n    flagged_at: new Date().toISOString()\n  });\n}\n\nreturn flagged.length > 0\n  ? flagged.map(f => ({ json: f }))\n  : [{ json: { message: 'No campaigns flagged. CAC is within threshold.', date: kpi.date, cac_usd: kpi.cac_usd } }];"
      },
      "id": "node-flag-campaigns",
      "name": "Flag Underperforming Campaigns",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 520]
