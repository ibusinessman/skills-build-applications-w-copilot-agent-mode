    {
      "parameters": {
        "jsCode": "// =============================================\n// KoneksAI KPI Calculator\n// Reads all sheet data from previous nodes and\n// computes: CAC, LTV, churn_rate, conversion_rate\n// =============================================\n\n// Get data from all previous nodes\nconst allItems = $input.all();\n\n// Each item comes from a different branch — collect by node name\n// n8n merges parallel branches; we index by order\n// In this merged flow, items arrive as [leads[], analytics[], payments[], clients[]]\n// We reference via $('node-name').all() pattern\n\nconst leadsData = $('Sheets: Read Leads').all().map(i => i.json);\nconst paymentsData = $('Sheets: Read Payments').all().map(i => i.json);\nconst clientsData = $('Sheets: Read Clients').all().map(i => i.json);\nconst analyticsData = $('Sheets: Read Analytics').all().map(i => i.json);\n\n// ---- Date helpers ----\nconst now = new Date();\n// Haiti is UTC-5 (no DST in 2025)\nconst haitiOffset = -5 * 60;\nconst haitiNow = new Date(now.getTime() + haitiOffset * 60 * 1000);\nconst todayStr = haitiNow.toISOString().split('T')[0];\n\nconst startOfToday = new Date(todayStr + 'T00:00:00-05:00');\nconst startOfMonth = new Date(todayStr.slice(0, 8) + '01T00:00:00-05:00');\nconst thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);\n\nconst isToday = (dateStr) => {\n  if (!dateStr) return false;\n  return dateStr.toString().startsWith(todayStr);\n};\n\nconst isThisMonth = (dateStr) => {\n  if (!dateStr) return false;\n  return dateStr.toString().startsWith(todayStr.slice(0, 7));\n};\n\nconst isWithinDays = (dateStr, days) => {\n  if (!dateStr) return false;\n  const d = new Date(dateStr);\n  return d >= new Date(now.getTime() - days * 24 * 60 * 60 * 1000);\n};\n\n// ---- Lead metrics ----\nconst newLeadsToday = leadsData.filter(l => isToday(l.timestamp)).length;\nconst totalLeads = leadsData.length;\nconst soldLeads = leadsData.filter(l => l.stage === 'sold').length;\n\n// ---- Payment / revenue metrics ----\nconst paymentsToday = paymentsData.filter(p => p.status === 'success' && isToday(p.timestamp));\nconst paymentsThisMonth = paymentsData.filter(p => p.status === 'success' && isThisMonth(p.timestamp));\nconst successPaymentsAll = paymentsData.filter(p => p.status === 'success');\n\nconst newClientsToday = paymentsToday.length;\nconst newClientsThisMonth = paymentsThisMonth.length;\n\nconst totalRevenueToday_HTG = paymentsToday.reduce((sum, p) => sum + (parseFloat(p.amount_htg) || 0), 0);\nconst totalRevenueToday_USD = paymentsToday.reduce((sum, p) => sum + (parseFloat(p.amount_usd) || 0), 0);\n\nconst totalRevenueAllTime_USD = successPaymentsAll.reduce((sum, p) => sum + (parseFloat(p.amount_usd) || 0), 0);\n\n// ---- Client metrics ----\nconst activeClients = clientsData.filter(c =>\n  ['active', 'active_30d', 'active_60d', 'onboarding'].includes(c.status)\n);\nconst churnedClients = clientsData.filter(c => c.status === 'churned');\nconst totalClientsAtStartOfMonth = clientsData.filter(c => {\n  // Clients who existed before start of month\n  return c.onboard_date && new Date(c.onboard_date) < startOfMonth;\n}).length;\n\nconst avgMonthlyRevenue_USD = activeClients.length > 0\n  ? activeClients.reduce((sum, c) => sum + ((parseFloat(c.monthly_revenue_htg) || 0) / 154), 0) / activeClients.length\n  : 0;\n\n// ---- KPI Calculations ----\n// CAC = total ad spend today / new clients today\n// Ad spend comes from Meta Ads API; use environment variable or last Analytics row as proxy\nconst lastAnalyticsRow = analyticsData.length > 0 ? analyticsData[analyticsData.length - 1] : {};\nconst adSpendToday_USD = parseFloat(process.env.META_AD_SPEND_TODAY_USD || lastAnalyticsRow.total_ad_spend_usd || 0);\n\nconst cac_usd = newClientsToday > 0\n  ? parseFloat((adSpendToday_USD / newClientsToday).toFixed(2))\n  : null;\n\n// LTV = average monthly revenue * 12\nconst ltv_usd = parseFloat((avgMonthlyRevenue_USD * 12).toFixed(2));\n\n// Churn rate = churned this month / total clients at start of month\nconst churnedThisMonth = churnedClients.filter(c =>\n  c.notes && c.notes.includes(todayStr.slice(0, 7))\n).length;\nconst churn_rate = totalClientsAtStartOfMonth > 0\n  ? parseFloat((churnedThisMonth / totalClientsAtStartOfMonth).toFixed(4))\n  : 0;\n\n// Conversion rate = sold leads / total leads\nconst conversion_rate = totalLeads > 0\n  ? parseFloat((soldLeads / totalLeads).toFixed(4))\n  : 0;\n\n// CAC alert threshold\nconst CAC_THRESHOLD_USD = 20;\nconst alert_cac_exceeded = cac_usd !== null && cac_usd > CAC_THRESHOLD_USD;\n\n// ---- Compose KPI object ----\nconst kpi = {\n  sync_id: `kpi-${todayStr}`,\n  date: todayStr,\n  new_leads: newLeadsToday,\n  new_clients: newClientsToday,\n  new_clients_this_month: newClientsThisMonth,\n  total_revenue_htg: parseFloat(totalRevenueToday_HTG.toFixed(2)),\n  total_revenue_usd: parseFloat(totalRevenueToday_USD.toFixed(2)),\n  total_revenue_all_time_usd: parseFloat(totalRevenueAllTime_USD.toFixed(2)),\n  total_ad_spend_usd: parseFloat(adSpendToday_USD.toFixed(2)),\n  cac_usd: cac_usd,\n  ltv_usd: ltv_usd,\n  churn_rate: churn_rate,\n  conversion_rate: conversion_rate,\n  active_clients_total: activeClients.length,\n  total_leads: totalLeads,\n  alert_cac_exceeded: alert_cac_exceeded,\n  synced_at: now.toISOString()\n};\n\nreturn [{ json: kpi }];"
      },
      "id": "node-calculate-kpis",
